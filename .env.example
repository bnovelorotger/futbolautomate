APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/futbol_balear
LOG_LEVEL=INFO
LOG_JSON=false
TIMEZONE=Europe/Madrid
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRIES=3
REQUEST_BACKOFF_SECONDS=0.75
USER_AGENT=FutbolBalearBot/0.1 (+https://example.com; contacto@example.com)
RESPECT_ROBOTS_TXT=true
DEBUG_RESPONSE_DIR=.debug_responses
DRY_RUN=false
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8000/callback
X_SCOPES=tweet.read tweet.write users.read offline.access
X_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com
X_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_TOKEN_URL=https://api.x.com/2/oauth2/token
ENABLE_TEAM_MENTIONS=true
MAX_MENTIONS_PER_POST=3
